ADOBE_CLIENT_ID=your_adobe_client_id_here
ADOBE_CLIENT_SECRET=your_adobe_client_secret_here
ADOBE_ORG_ID=your_adobe_org_id_here

# Optional: Set this if you want to explicitly define the GCP project 
# (otherwise it can be set in config.json or inferred from standard GCP env vars)
GCP_PROJECT_ID=your_gcp_project_id

# Optional: Path to GCP Service Account JSON (Local testing only)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account.json
